# Required
POSTGRES_PASSWORD=changeme

# Optional (defaults shown)
POSTGRES_USER=clustec
POSTGRES_DB=clustec
NETWORK=devnet
ANALYSIS_INTERVAL_MS=600000

# Admin auth (server) — both required
ADMIN_PASSWORD=admin
JWT_SECRET=jwt-secret-at-least-32-chars

# Web — Caddy listens on WEB_PORT (default 3001)
# For production with TLS: set DOMAIN to your domain, WEB_PORT=443
WEB_PORT=3001
DOMAIN=:3001
