{
  "name": "clustec",
  "private": true,
  "packageManager": "yarn@4.9.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test && cd packages/analyzer && uv run pytest tests/ -v",
    "lint": "turbo run lint",
    "db:generate": "turbo run db:generate --filter=@clustec/common",
    "db:migrate": "turbo run db:migrate --filter=@clustec/common",
    "db:up": "docker compose -f docker-compose.local.yml up -d",
    "db:down": "docker compose -f docker-compose.local.yml down",
    "build:docker": "bash build-docker.sh",
    "deploy": "bash deploy.sh"
  },
  "devDependencies": {
    "turbo": "^2",
    "typescript": "^5.7"
  },
  "engines": {
    "node": ">=24"
  }
}
